generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String                @id @default(uuid())
  name                 String
  email                String?               @unique
  isActive             Boolean               @default(true)
  status               CompanyStatus         @default(ACTIVE)
  suspensionReason     String?
  suspendedAt          DateTime?
  suspendedBy          String?
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  officeLatitude       Decimal?              @db.Decimal(10, 7)
  officeLongitude      Decimal?              @db.Decimal(10, 7)
  officeRadiusMeters   Int?
  accountingEntries    AccountingEntry[]
  attendanceRecords    AttendanceRecord[]
  appeals              CompanyAppeal[]
  departments          Department[]
  employees            Employee[]
  employmentDetails    EmploymentDetails[]
  leaveRequests        LeaveRequest[]
  payrollRecords       PayrollRecord[]
  recruitmentPositions RecruitmentPosition[]
  salaryAssignments    SalaryAssignment[]
  users                User[]

  @@index([status, deletedAt])
}

model CompanyAppeal {
  id        String   @id @default(uuid())
  companyId String?
  email     String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([companyId, status])
  @@index([email])
}

model User {
  id           String    @id @default(uuid())
  companyId    String
  name         String
  email        String
  passwordHash String
  role         UserRole  @default(EMPLOYEE)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee?
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
  @@index([companyId])
}

model Department {
  id                   String                @id @default(uuid())
  companyId            String
  name                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees            Employee[]
  recruitmentPositions RecruitmentPosition[]

  @@unique([companyId, name])
  @@index([companyId])
}

model RecruitmentPosition {
  id           String      @id @default(uuid())
  companyId    String
  departmentId String?
  title        String
  openings     Int         @default(1)
  status       String      @default("Open")
  priority     String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id])

  @@index([companyId])
  @@index([companyId, departmentId])
}

model Employee {
  id                String             @id @default(uuid())
  companyId         String
  userId            String?            @unique
  departmentId      String?
  firstName         String
  lastName          String
  email             String?
  phone             String?
  hireDate          DateTime?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department        Department?        @relation(fields: [departmentId], references: [id])
  user              User?              @relation(fields: [userId], references: [id])
  employmentDetails EmploymentDetails?
  leaveRequests     LeaveRequest[]
  payrollRecords    PayrollRecord[]
  salaryAssignments SalaryAssignment[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([companyId, departmentId])
}

model EmploymentDetails {
  id             String    @id @default(uuid())
  companyId      String
  employeeId     String    @unique
  salary         Decimal?  @db.Decimal(12, 2)
  currency       String    @default("NGN")
  jobTitle       String?
  employmentType String?
  startDate      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AttendanceRecord {
  id                     String           @id @default(uuid())
  companyId              String
  employeeId             String
  workDate               DateTime
  clockInAt              DateTime?
  clockOutAt             DateTime?
  status                 AttendanceStatus @default(clocked_in)
  notes                  String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  clockInLatitude        Decimal?         @db.Decimal(10, 7)
  clockInLongitude       Decimal?         @db.Decimal(10, 7)
  clockInDistanceMeters  Int?
  clockOutLatitude       Decimal?         @db.Decimal(10, 7)
  clockOutLongitude      Decimal?         @db.Decimal(10, 7)
  clockOutDistanceMeters Int?
  company                Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee               Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, employeeId, workDate])
  @@index([companyId, employeeId])
}

model LeaveRequest {
  id         String      @id @default(uuid())
  companyId  String
  employeeId String
  type       String
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveStatus @default(pending)
  reviewedAt DateTime?
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([companyId, employeeId])
  @@index([companyId, startDate, endDate])
}

model SalaryAssignment {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("NGN")
  effectiveAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId])
}

model PayrollRecord {
  id          String        @id @default(uuid())
  companyId   String
  employeeId  String
  month       Int
  year        Int
  grossAmount Decimal       @db.Decimal(12, 2)
  deductions  Decimal       @default(0) @db.Decimal(12, 2)
  netAmount   Decimal       @db.Decimal(12, 2)
  status      PayrollStatus @default(unpaid)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, employeeId, month, year])
  @@index([companyId])
}

model AccountingEntry {
  id          String         @id @default(uuid())
  companyId   String
  type        AccountingType
  amount      Decimal        @db.Decimal(12, 2)
  category    String
  description String?
  entryDate   DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, type])
  @@index([companyId, entryDate])
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  EMPLOYEE
  admin
  HR
  employee
  staff
}

enum AttendanceStatus {
  clocked_in
  clocked_out
}

enum PayrollStatus {
  unpaid
  paid
}

enum AccountingType {
  income
  expense
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum LeaveStatus {
  pending
  approved
  rejected
}
